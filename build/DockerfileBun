ARG VARIANT=1.3.10-debian
ARG ROOTCERT="./radrealm.crt"
FROM oven/bun:${VARIANT}

RUN apt-get update \
    && apt-get -y install --no-install-recommends \
    git \
    nano \
    npm \
    openssh-client \
    curl \
    gpg \
    ca-certificates \
    lsb-release \
    && apt-get auto-remove -y \
    && apt-get clean -y \
    && rm -rf /var/lib/apt/lists/* \
    && chsh -s $(which bash) bun \
    && echo 'export PS1="\e[01;32m\u\e[m:\e[01;34m\w\e[m\$ "' >> /home/bun/.bashrc
    
RUN curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg

RUN echo xxxx $(lsb_release -cs) xxx
RUN echo \
  "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] \
  https://download.docker.com/linux/debian \
  $(lsb_release -cs) stable" | tee /etc/apt/sources.list.d/docker.list > /dev/null

RUN cat /etc/apt/sources.list.d/docker.list

RUN apt-get update
RUN apt-get -y install docker-ce-cli
    
# Add a root certificate if necessary
RUN mkdir junk
COPY . ./junk
RUN cp ./junk/*.crt /usr/local/share/ca-certificates/
RUN update-ca-certificates
RUN rm -rf ./junk

RUN groupadd -g 1001 docker
RUN usermod -aG docker bun

USER bun
